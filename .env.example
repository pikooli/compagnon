# Speechmatics Flow — voice STT/TTS
SPEECHMATICS_API_KEY=

# Backboard.io — memory layer
BACKBOARD_API_KEY=

# Cerebras — brain LLM
CEREBRAS_API_KEY=

# MongoDB — contacts & products storage
MONGO_URI=

# Qdrant — vector search for contacts & products
QDRANT_URL=
QDRANT_API_KEY=

# OpenAI — text embeddings for Qdrant
OPENAI_API_KEY=

# Google Calendar — OAuth2 credentials (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google-calendar/callback

# Google Calendar — optional: bootstrap tokens without OAuth flow
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCESS_TOKEN=
GOOGLE_EXPIRY_DATE=

# Google Maps Embed — show map in calendar event detail (optional, free API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Speechmatics Flow — voice agent template IDs
NEXT_PUBLIC_MALE_AGENT_ID=
NEXT_PUBLIC_FEMALE_AGENT_ID=
