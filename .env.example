# Speechmatics Flow — voice STT/TTS
SPEECHMATICS_API_KEY=

# Backboard.io — memory layer
BACKBOARD_API_KEY=

# Cerebras — brain LLM
CEREBRAS_API_KEY=

# Google Calendar — OAuth2 credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000

# Google Calendar — optional: bootstrap tokens without OAuth flow
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCESS_TOKEN=
GOOGLE_EXPIRY_DATE=

# Google Gmail — separate OAuth callback URI (reuses GOOGLE_CLIENT_ID/SECRET)
GOOGLE_GMAIL_REDIRECT_URI=http://localhost:3000/api/google-gmail/callback
